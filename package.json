{
  "name": "rythm",
  "version": "0.1.0",
  "description": "Personal PWA for shaping a repeating weekly life rhythm.",
  "private": true,
  "type": "commonjs",
  "engines": {
    "node": ">=25"
  },
  "scripts": {
    "dev": "NODE_ENV=development node src/server/server.js",
    "build": "node scripts/build.js",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:week-layout": "node scripts/check-week-layout.js",
    "start": "NODE_ENV=production node src/server/server.js",
    "deploy:vps": "scripts/deploy-vps.sh",
    "setup:env": "node scripts/setup-env.js",
    "hash-password": "node scripts/hash-password.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "svelte": "^5.19.7",
    "svelte-check": "^4.1.4",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  }
}
